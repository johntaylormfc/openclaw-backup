    // Draw X Growth line chart
    function drawXChart(canvasId, history, actualKey, goalKey, color) {
      const canvas = document.getElementById(canvasId);
      if (!canvas || !history || history.length === 0) return;
      const ctx = canvas.getContext('2d');
      const w = canvas.width;
      const h = canvas.height;
      const padding = 20;
      
      // Find max value for scaling
      let maxVal = 0;
      history.forEach(d => {
        maxVal = Math.max(maxVal, d[actualKey] || 0, d[goalKey] || 0);
      });
      maxVal = Math.max(maxVal, 10); // minimum scale
      
      const xStep = (w - 2 * padding) / Math.max(1, history.length - 1);
      
      // Clear
      ctx.clearRect(0, 0, w, h);
      
      // Draw grid lines - brighter
      ctx.strokeStyle = 'rgba(100,100,100,0.4)';
      ctx.lineWidth = 1;
      for (let i = 0; i <= 4; i++) {
        const y = padding + (h - 2 * padding) * i / 4;
        ctx.beginPath();
        ctx.moveTo(padding, y);
        ctx.lineTo(w - padding, y);
        ctx.stroke();
      }
      
      // Draw Y-axis labels - brighter, larger
      ctx.fillStyle = '#ffffff';
      ctx.font = 'bold 11px sans-serif';
      ctx.textAlign = 'right';
      for (let i = 0; i <= 4; i++) {
        const y = padding + (h - 2 * padding) * i / 4;
        const val = Math.round(maxVal * (4 - i) / 4);
        ctx.fillText(val.toString(), padding - 6, y + 4);
      }
      
      // Draw X axis labels (Day 1, Day 2, etc) - brighter, larger
      ctx.fillStyle = '#ffffff';
      ctx.font = 'bold 11px sans-serif';
      ctx.textAlign = 'center';
      history.forEach((d, i) => {
        const x = padding + i * xStep;
        ctx.fillText(d.day, x, h - 8);
      });
      
      // Draw goal line (dashed, lighter gray for visibility)
      ctx.strokeStyle = 'rgba(180,180,180,0.7)';
      ctx.setLineDash([5, 5]);
      ctx.lineWidth = 2;
      ctx.beginPath();
      history.forEach((d, i) => {
        const x = padding + i * xStep;
        const y = h - padding - ((d[goalKey] || 0) / maxVal) * (h - 2 * padding);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.stroke();
      
      // Draw actual line (solid, colored)
      ctx.strokeStyle = color;
      ctx.setLineDash([]);
      ctx.lineWidth = 2;
      ctx.beginPath();
      history.forEach((d, i) => {
        const x = padding + i * xStep;
        const y = h - padding - ((d[actualKey] || 0) / maxVal) * (h - 2 * padding);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      });
      ctx.stroke();
      
      // Draw points
      history.forEach((d, i) => {
        const x = padding + i * xStep;
        const y = h - padding - ((d[actualKey] || 0) / maxVal) * (h - 2 * padding);
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.arc(x, y, 4, 0, Math.PI * 2);
        ctx.fill();
      });
    }
    
