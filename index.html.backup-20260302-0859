        if (codingPlanData && !codingPlanData.error) {
          if (mpRemaining) mpRemaining.textContent = codingPlanData.remaining || '--';
          if (mpUsed) mpUsed.textContent = (codingPlanData.used || '--') + ' / ' + (codingPlanData.total || '--');
          if (mpPercent) mpPercent.textContent = (codingPlanData.percentUsed || '--') + '%';
        }
        
        // Render Kanban
        console.log('Kanban data:', kanbanData);
        renderKanban(kanbanData);
        
        // Update system stats (with null checks)
        const cpuTemp = document.getElementById('cpuTemp');
        const cpuLoad = document.getElementById('cpuLoad');
        const memUsage = document.getElementById('memUsage');
        const diskUsage = document.getElementById('diskUsage');
        const netUsage = document.getElementById('netUsage');
        const sysUptime = document.getElementById('sysUptime');
        if (cpuTemp) cpuTemp.textContent = systemData.cpuTemp || '--';
        if (cpuLoad) cpuLoad.textContent = systemData.load || '--';
        if (memUsage) memUsage.textContent = systemData.mem?.percent ? systemData.mem.percent + '%' : '--';
        if (diskUsage) diskUsage.textContent = systemData.disk?.percent ? systemData.disk.percent + '%' : '--';
        if (netUsage) netUsage.textContent = (systemData.network?.rx || '0') + ' / ' + (systemData.network?.tx || '0');
        if (sysUptime) sysUptime.textContent = systemData.uptime || '--';

        // Charts (with null checks)
        const cpuChart = document.getElementById('cpuChart');
        const memChart = document.getElementById('memChart');
        if (cpuChart && memChart) {
          const running = containers.filter(c => c.State === 'running');
          const avgCpu = running.length ? (running.reduce((a,b) => a + parseFloat(b.cpu||0), 0) / running.length).toFixed(1) : 0;
          const avgMem = running.length ? (running.reduce((a,b) => a + parseFloat(b.mem||0), 0) / running.length).toFixed(1) : 0;
          drawDoughnut('cpuChart', avgCpu, 100-avgCpu, '#ef4444');
          drawDoughnut('memChart', avgMem, 100-avgMem, '#a855f7');
        }

        // Render containers
        renderContainers();
        
        // NAS (with null check)
        const nasDiv = document.getElementById('nas');
        if (nasDiv) {
          nasDiv.innerHTML = Object.entries(nasData).map(([k,v]) => 
            '<div class="flex py-2"><span>' + k + '</span><span class="font-mono text-green">' + v + '</span></div>'
          ).join('') || 'Loading...';
        }

        // VPN (with null check)
        const vpnDiv = document.getElementById('vpn');
        if (vpnDiv) {
          vpnDiv.innerHTML = 
            '<div class="flex py-2"><span>Country</span><span class="text-green">' + (vpnData.country || 'CH') + '</span></div>' +
            '<div class="flex py-2"><span>Ping</span><span class="text-blue">' + (vpnData.ping || '45ms') + '</span></div>' +
            '<div class="flex py-2"><span>Forward</span><span class="text-purple">' + (vpnData.portForward || 'On') + '</span></div>';
        }

        // Todoist Tasks
        const todoistDiv = document.getElementById('todoistTasks');
        if (todoistData && todoistData.tasks && todoistData.tasks.length > 0) {
          todoistDiv.innerHTML = todoistData.tasks.slice(0, 15).map(t => {
            const priorityColors = { 4: '#ef4444', 3: '#f97316', 2: '#eab308', 1: '#6b7280' };
            const priorityColor = priorityColors[t.priority] || '#6b7280';
            return '<div class="flex" style="padding: 0.5rem; border-bottom: 1px solid var(--border-color); align-items: center;">' +
              '<input type="checkbox" onchange="completeTask(\'' + t.id + '\')" style="margin-right: 0.75rem;">' +
              '<span style="flex: 1;">' + t.content + '</span>' +
              '<span style="font-size: 0.75rem; color: ' + priorityColor + '; margin-right: 0.5rem;">' + (t.project || '') + '</span>' +
              (t.due ? '<span style="font-size: 0.75rem; color: var(--text-secondary);">' + t.due + '</span>' : '') +
            '</div>';
          }).join('');
        } else {
          todoistDiv.innerHTML = '<div style="color: var(--text-secondary);">No tasks or Todoist unavailable</div>';
        }

        const lastUpdate = document.getElementById('lastUpdate');
        if (lastUpdate) lastUpdate.textContent = 'Last update: ' + new Date().toLocaleTimeString();
        
        // Restore drag state after reload
        if (savedItem) {
          document.body.setAttribute('data-drag-item', savedItem);
          document.body.setAttribute('data-drag-col', savedCol);
        }
        } catch(e) {
          console.error('loadData error:', e);
        }
      });
    }

    function renderContainers() {
      const search = document.getElementById('searchBox').value.toLowerCase();
      let filtered = containers.filter(c => 
        c.name.toLowerCase().includes(search) || 
        (c.Image && c.Image.toLowerCase().includes(search))
      );

      // Sort
      filtered.sort((a, b) => {
        let valA, valB;
        switch(sortCol) {
          case 'name': valA = a.name; valB = b.name; break;
          case 'status': valA = a.State; valB = b.State; break;
          case 'cpu': valA = parseFloat(a.cpu||0); valB = parseFloat(b.cpu||0); break;
          case 'mem': valA = parseFloat(a.mem||0); valB = parseFloat(b.mem||0); break;
          case 'ports': valA = (a.Ports?.length||0); valB = (b.Ports?.length||0); break;
          default: valA = a.name; valB = b.name;
        }
        if (valA < valB) return sortAsc ? -1 : 1;
        if (valA > valB) return sortAsc ? 1 : -1;
        return 0;
      });

      const tbody = document.getElementById('containers');
      if (tbody) {
        tbody.innerHTML = filtered.map(c => {
        const ports = c.Ports ? c.Ports.map(p => p.PublicPort || p.PrivatePort).filter(p => p).join(', ') : '-';
        const isRunning = c.State === 'running';
        return '<tr>' +
          '<td>' + c.name + '</td>' +
          '<td class="' + (isRunning ? 'running' : 'stopped') + '">' + (c.State || 'N/A') + '</td>' +
          '<td>' + (c.cpu || '0') + '%</td>' +
          '<td>' + (c.mem || '0') + '%</td>' +
          '<td style="color:var(--text-secondary)">' + ports + '</td>' +
          '<td>' +
            (isRunning ? 
              '<button class="btn btn-stop" onclick="stopContainer(\'' + c.name + '\')">Stop</button>' :
              '<button class="btn btn-start" onclick="startContainer(\'' + c.name + '\')">Start</button>'
            ) +
            '<button class="btn btn-restart" onclick="restart(\'' + c.name + '\')">Restart</button>' +
            '<button class="btn btn-logs" onclick="logs(\'' + c.name + '\')">Logs</button>' +
          '</td></tr>';
      }).join('');
      }
    }

    function filterContainers() {
      renderContainers();
    }

    function sortTable(e) {
      const col = e.target.dataset.sort;
      if (sortCol === col) sortAsc = !sortAsc;
      else { sortCol = col; sortAsc = true; }
      renderContainers();
    }

    function setRefreshRate() {
      const rate = parseInt(document.getElementById('refreshRate').value);
      refreshInterval = rate;
      if (intervalId) clearInterval(intervalId);
      if (rate > 0) intervalId = setInterval(loadData, rate);
    }

    function restart(name) {
      if(confirm('Restart ' + name + '?')) {
        fetch('/api/restart/' + name, { method: 'POST' }).then(() => setTimeout(loadData, 2000));
      }
    }

    function stopContainer(name) {
      if(confirm('Stop ' + name + '?')) {
        fetch('/api/stop/' + name, { method: 'POST' }).then(() => setTimeout(loadData, 2000));
      }
    }

    function startContainer(name) {
      fetch('/api/start/' + name, { method: 'POST' }).then(() => setTimeout(loadData, 2000));
    }

    function logs(name) {
      fetch('/api/logs/' + name).then(r => r.json()).then(data => {
        alert(data.logs ? data.logs.substr(0, 3000) : 'No logs');
      });
    }

    function completeTask(taskId) {
      if(confirm('Complete this task in Todoist?')) {
        fetch('/api/tasks/' + taskId + '/close', { method: 'POST' }).then(() => {
          setTimeout(loadData, 500);
        });
      }
    }

    // ============ KANBAN FUNCTIONS ============
    const kanbanColumns = [
      { id: 'idea', name: '💡 Ideas', color: '#a855f7' },
      { id: 'backlog', name: '📋 Backlog', color: '#3b82f6' },
      { id: 'in-progress', name: '🔄 In Progress', color: '#f59e0b' },
      { id: 'blocked', name: '⛔ Blocked', color: '#ef4444' }
    ];

    function renderKanban(kanbanData) {
      console.log('Rendering kanban with:', kanbanData);
      try {
      const board = document.getElementById('kanbanBoard');
      board.innerHTML = kanbanColumns.map(col => {
        // Get tasks for this column - only 'new' tasks go to backlog, ideas stay in ideas column
        const tasks = (kanbanData.tasks || []).filter(t => t.column === col.id || t.column === 'new').sort((a,b) => (a.sortOrder || 0) - (b.sortOrder || 0));
        // Ideas only go in Ideas column
        const ideas = (kanbanData.ideas || []).filter(t => t.column === col.id).sort((a,b) => (a.sortOrder || 0) - (b.sortOrder || 0));
        const allItems = [...ideas, ...tasks];
        
        return '<div data-col-id="' + col.id + '" style="min-width: 200px; flex: 1;" ondragover="allowDrop(event, \'' + col.id + '\')" ondrop="handleDrop(event, \'' + col.id + '\')">' +
          '<div style="padding: 0.5rem; border-radius: 0.5rem; background: ' + col.color + '; color: white; font-weight: bold; margin-bottom: 0.5rem;">' +
            col.name + ' (' + allItems.length + ')' +
          '</div>' +
          '<div style="display: flex; flex-direction: column; gap: 0.5rem;">' +
            allItems.map(item => renderKanbanCard(item, col)).join('') +
          '</div>' +
        '</div>';
      }).join('');
      } catch(e) {
        console.error('Kanban render error:', e);
        const kbBoard = document.getElementById('kanbanBoard');
        if (kbBoard) kbBoard.innerHTML = '<div class="text-red">Error: ' + e.message + '</div>';
      }
    }

    function renderKanbanCard(item, col) {
      const isIdea = item.type === 'idea';
      const inIdeasColumn = col.id === 'idea' || col.id === 'ideas';
      
      // Show attempt count if > 1
      let attemptHtml = '';
      if (item.attempt_count && item.attempt_count > 1) {
        const attemptColor = item.attempt_count >= 3 ? '#ef4444' : '#f59e0b';
        attemptHtml = '<div style="font-size: 0.7rem; color: ' + attemptColor + '; margin-bottom: 0.25rem;">🔄 Attempt ' + item.attempt_count + '</div>';
      }
      
      let blockerHtml = '';
      if (item.column === 'blocked' && item.blockerReason) {
        blockerHtml = '<div style="font-size: 0.75rem; color: #ef4444; padding: 0.25rem; background: rgba(239,68,68,0.2); border-radius: 0.25rem; margin-top: 0.25rem;">⛔ ' + item.blockerReason + '</div>';
      }
      
      let failureHtml = '';
      if (item.failure_reason) {
        failureHtml = '<div style="font-size: 0.7rem; color: #f97316; padding: 0.25rem; background: rgba(249,115,22,0.2); border-radius: 0.25rem; margin-top: 0.25rem;">❌ ' + item.failure_reason + '</div>';
      }
      
      let agentNotesHtml = '';
      if (item.agentNotes) {
        agentNotesHtml = '<div style="font-size: 0.75rem; color: #60a5fa; padding: 0.25rem; background: rgba(96,165,250,0.2); border-radius: 0.25rem; margin-top: 0.25rem;">📝 ' + item.agentNotes + '</div>';
      }

      let buttonsHtml = '';
      if (inIdeasColumn) {
        // Ideas column: show Accept/Reject/Delete buttons
        buttonsHtml = '<div style="display: flex; gap: 0.25rem; margin-top: 0.5rem;">' +
          '<button class="btn" style="padding: 0.25rem 0.5rem; font-size: 0.7rem; background: #22c55e;" onclick="acceptIdea(\'' + item.id + '\')">✓ Accept</button>' +
          '<button class="btn" style="padding: 0.25rem 0.5rem; font-size: 0.7rem; background: #ef4444;" onclick="rejectIdea(\'' + item.id + '\')">✗ Reject</button>' +
          '<button class="btn" style="padding: 0.25rem 0.5rem; font-size: 0.7rem; background: #6b7280;" onclick="deleteItem(\'' + item.id + '\', \'' + item.type + '\')">🗑️</button>' +
        '</div>';
      } else {
        // Other columns: show move buttons + delete + retry if failed
        const nextCols = kanbanColumns.filter(c => c.id !== col.id && c.id !== 'idea');
        
        // Add retry button for failed/blocked tasks
        let retryButton = '';
        if (item.column === 'blocked' || item.failure_reason) {
          retryButton = '<button class="btn" style="padding: 0.25rem 0.5rem; font-size: 0.7rem; background: #f59e0b;" onclick="retryTask(\'' + item.id + '\')">🔄 Retry</button>';
        }
        
        // Add block button for tasks that need human help
        let blockButton = '';
        if (item.column !== 'blocked') {
          blockButton = '<button class="btn" style="padding: 0.25rem 0.5rem; font-size: 0.7rem; background: #ef4444;" onclick="blockTask(\'' + item.id + '\')">⛔ Block</button>';
        }
        
        buttonsHtml = '<div style="display: flex; gap: 0.25rem; margin-top: 0.5rem; flex-wrap: wrap;">' +
          nextCols.slice(0, 3).map(nextCol => 
            '<button class="btn" style="padding: 0.25rem 0.5rem; font-size: 0.7rem; background: var(--accent-blue);" onclick="moveTask(\'' + item.id + '\', \'' + nextCol.id + '\')">' + nextCol.name + '</button>'
          ).join('') +
          retryButton + blockButton +
          '<button class="btn" style="padding: 0.25rem 0.5rem; font-size: 0.7rem; background: #6b7280;" onclick="deleteItem(\'' + item.id + '\', \'' + item.type + '\')">🗑️</button>' +
        '</div>';
      }

      return '<div draggable="true" data-item-id="' + item.id + '" ondragstart="dragStart(event, \'' + item.id + '\', \'' + col.id + '\')" style="background: var(--bg-secondary); padding: 0.75rem; border-radius: 0.5rem; border: 1px solid var(--border-color); cursor: move;">' +
        attemptHtml +
        '<div style="font-weight: 600; font-size: 0.875rem;">' + (isIdea ? '💡 ' : '') + item.title + '</div>' +
        (item.description ? '<div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.25rem;">' + item.description + '</div>' : '') +
        blockerHtml + failureHtml + agentNotesHtml +
        buttonsHtml +
      '</div>';
    }

    document.body.removeAttribute("data-drag-item"); document.body.removeAttribute("data-drag-col");

    function dragStart(e, itemId, colId) {
      document.body.setAttribute('data-drag-item', itemId);
      document.body.setAttribute('data-drag-col', colId);
      e.dataTransfer.effectAllowed = 'move';
      const debug = document.getElementById('debug-info');
      debug.innerHTML = 'DragStart: item=' + itemId + ' col=' + colId;
    }

    function allowDrop(e, colId) {
      e.preventDefault(); // Just allow the drop - don't process here
    }
    
    function handleDrop(e, colId) {
      e.preventDefault();
      const itemId = document.body.getAttribute('data-drag-item');
      const fromCol = document.body.getAttribute('data-drag-col');
      const debug = document.getElementById('debug-info');
      debug.innerHTML = 'Drop: item=' + itemId + ' from=' + fromCol + ' to=' + colId;
      if (!itemId) return;
      
      if (fromCol !== colId) {
        fetch('/api/kanban/' + itemId + '/move', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({column: colId})
        }).then(() => {
          updateColumnOrder(colId).then(() => loadData());
        });
      } else {
        updateColumnOrder(colId).then(() => loadData());
      }
      document.body.removeAttribute('data-drag-item');
      document.body.removeAttribute('data-drag-col');
    }

    async function updateColumnOrder(colId) {
      const debug = document.getElementById('debug-info');
      const colEl = document.querySelector('[ondragover*="' + colId + '"]');
      debug.innerHTML += ' | colEl=' + (colEl ? 'found' : 'NOT FOUND');
      if (!colEl) return Promise.resolve();
      
      const cards = colEl.querySelectorAll('[draggable="true"]');
      const itemIds = Array.from(cards).map(c => c.dataset.itemId).filter(Boolean);
      debug.innerHTML += ' | items=' + itemIds.join(',');
      
      if (itemIds.length > 1) {
        return fetch('/api/kanban/reorder', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({itemIds})
        });
      }
      return Promise.resolve();
    }

    function showAddTask() {
      document.getElementById('addTaskModal').style.display = 'flex';
    }

    function hideAddTask() {
      document.getElementById('addTaskModal').style.display = 'none';
    }

    function addTask() {
      const title = document.getElementById('newTaskTitle').value;
      const desc = document.getElementById('newTaskDesc').value;
      const column = document.getElementById('newTaskColumn').value;
      
      if (!title) { alert('Please enter a title'); return; }
      
      fetch('/api/kanban', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title: title,
          description: desc,
          column: column,
          type: column === 'idea' ? 'idea' : 'task'
        })
      }).then(() => {
        hideAddTask();
        document.getElementById('newTaskTitle').value = '';
        document.getElementById('newTaskDesc').value = '';
        loadData();
      });
    }

    function moveTask(taskId, newColumn) {
      if (newColumn === 'blocked') {
        const reason = prompt('Enter blocker reason:');
        if (!reason) return;
        fetch('/api/kanban/' + taskId + '/move', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ column: newColumn, blockerReason: reason })
        }).then(() => loadData());
      } else if (newColumn === 'complete' || newColumn === 'completed') {
        // Auto-record completion with timestamp
        fetch('/api/kanban/' + taskId + '/move', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ column: 'complete', completionNotes: 'Completed via kanban' })
        }).then(() => loadData());
      } else {
        fetch('/api/kanban/' + taskId + '/move', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ column: newColumn })
        }).then(() => loadData());
      }
    }

    function acceptIdea(taskId) {
      // Move idea to backlog
      fetch('/api/kanban/' + taskId + '/move', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ column: 'backlog' })
      }).then(() => loadData());
    }

    function rejectIdea(taskId) {
      if (confirm('Delete this idea?')) {
        fetch('/api/kanban/' + taskId, { method: 'DELETE' }).then(() => loadData());
      }
    }

    function retryTask(taskId) {
      // Retry a failed/blocked task - moves back to backlog with incremented attempt
      if (confirm('Retry this task? It will be moved to backlog for another attempt.')) {
        fetch('/api/kanban/' + taskId + '/retry', { method: 'POST' })
          .then(() => loadData())
          .catch(err => {
            // If retry endpoint doesn't exist, just move to backlog
            fetch('/api/kanban/' + taskId + '/move', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ column: 'backlog' })
            }).then(() => loadData());
          });
      }
    }

    function blockTask(taskId) {
      // Block a task - requires human intervention
      const reason = prompt('Why does this task need human intervention?');
      if (reason) {
        fetch('/api/kanban/' + taskId + '/block', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ blockerReason: reason })
        })
        .then(() => loadData())
        .catch(err => {
          alert('Could not block task. It may need to be moved to blocked column manually.');
        });
      }
    }

    function deleteItem(itemId, itemType) {
      const typeLabel = itemType === 'idea' ? 'idea' : 'task';
      if (confirm('Delete this ' + typeLabel + '?')) {
        fetch('/api/kanban/' + itemId, { method: 'DELETE' }).then(() => loadData());
      }
    }

    // Initialize
    initTheme();

    // Quick actions
    const qaDiv = document.getElementById('quickActions');
    qaDiv.innerHTML = quickLinks.map(q => {
      const url = q.path ? `http://192.168.1.146:${q.port}${q.path}` : `http://192.168.1.146:${q.port}`;
      return '<a href="' + url + '" target="_blank" class="quick-link" style="background:' + q.color + ';">' + q.name + '</a>';
    }).join('');

    // Start loading data and notes
    setTimeout(function() {
      console.log('Loading data and notes...');
      loadData();
      loadNotes();
      setRefreshRate();
      // Initialize sidebar - show My Tasks by default
      showSection('tasks');
    }, 100);
    
    // Also reload notes periodically
    setInterval(loadNotes, 60000);
  </script>

  <!-- Note Modal -->
  <div id="noteModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000;">
    <div style="background: var(--bg-secondary); padding: 2rem; border-radius: 1rem; max-width: 500px; margin: 10% auto;">
      <h3 style="color: var(--text-primary); margin-bottom: 1rem;">Add Note</h3>
      <input type="text" id="noteTitle" placeholder="Title (optional)" style="width: 100%; padding: 0.5rem; margin-bottom: 0.5rem; border-radius: 0.5rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary);">
      <textarea id="noteText" placeholder="Note content..." rows="5" style="width: 100%; padding: 0.5rem; margin-bottom: 0.5rem; border-radius: 0.5rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary);"></textarea>
      <input type="text" id="noteTags" placeholder="Tags (comma separated): business-central, openclaw" style="width: 100%; padding: 0.5rem; margin-bottom: 1rem; border-radius: 0.5rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary);">
      <div style="display: flex; gap: 0.5rem;">
        <button onclick="saveNote()" class="btn" style="background: var(--accent-green);">Save</button>
        <button onclick="closeNoteModal()" class="btn" style="background: var(--bg-primary);">Cancel</button>
      </div>
    </div>
  </div>

  <script>
    let allNotes = [];
    
    function renderNotes(notes) {
      const container = document.getElementById('notesList');
      if (!notes || notes.length === 0) {
        container.innerHTML = '<div style="color: var(--text-secondary);">No notes yet. Click "+ Add Note" to create one.</div>';
        return;
      }
      
      container.innerHTML = notes.map(note => 
        '<div style="padding: 0.75rem; margin-bottom: 0.5rem; background: var(--bg-primary); border-radius: 0.5rem; border-left solid var(--accent-purple);">' +
          '<div style="font-weight: bold; color: var(--text-primary);">' + (note.title || 'Untitled') + '</div>' +
          '<div style="color: var(--text-secondary); font-size: 0.875rem; margin-top: 0.25rem;">' + (note.text || '').substring(0, 100) + '</div>' +
          '<div style="margin-top: 0.5rem;">' + 
            (typeof note.tags === 'string' ? JSON.parse(note.tags || '[]') : (note.tags || [])).map(t => '<span style="background: var(--accent-blue); padding: 0.125rem 0.5rem; border-radius: 1rem; font-size: 0.75rem; margin-right: 0.25rem;">' + t + '</span>').join('') +
          '</div>' +
          '<div style="color: var(--text-secondary); font-size: 0.75rem; margin-top: 0.5rem;">' + new Date(note.createdAt).toLocaleString() + '</div>' +
        '</div>'
      ).join('');
    }
    
    function searchNotes() {
      const query = document.getElementById('noteSearch').value.toLowerCase();
      if (!query) {
        renderNotes(allNotes);
        return;
      }
      const filtered = allNotes.filter(n => 
        (n.title && n.title.toLowerCase().includes(query)) ||
        (n.text && n.text.toLowerCase().includes(query)) ||
        (n.tags && n.tags.some(t => t.toLowerCase().includes(query)))
      );
      renderNotes(filtered);
    }
    
    function showAddNote() {
      document.getElementById('noteModal').style.display = 'block';
    }
    
    function closeNoteModal() {
      document.getElementById('noteModal').style.display = 'none';
      document.getElementById('noteTitle').value = '';
      document.getElementById('noteText').value = '';
      document.getElementById('noteTags').value = '';
    }
    
    async function saveNote() {
      const title = document.getElementById('noteTitle').value;
      const text = document.getElementById('noteText').value;
      const tagsInput = document.getElementById('noteTags').value;
      const tags = tagsInput ? tagsInput.split(',').map(t => t.trim()).filter(t => t) : ['general'];
      
      if (!text) {
        alert('Please enter note content');
        return;
      }
      
      try {
        await fetch('/api/notes', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ title, text, tags, source: 'dashboard' })
        });
        closeNoteModal();
        loadNotes();
      } catch(e) {
        alert('Error saving note: ' + e.message);
      }
    }
    
    // Voice Note
    let mediaRecorder = null;
    let audioChunks = [];
    
    function startVoiceNote() {
      if (!navigator.mediaDevices) {
        alert('Voice recording not supported in this browser');
        return;
      }
      
      if (mediaRecorder && mediaRecorder.state === 'recording') {
        mediaRecorder.stop();
        return;
      }
      
      navigator.mediaDevices.getUserMedia({ audio: true })
        .then(stream => {
          mediaRecorder = new MediaRecorder(stream);
          audioChunks = [];
          
          mediaRecorder.ondataavailable = e => audioChunks.push(e.data);
          mediaRecorder.onstop = async () => {
            const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
            const reader = new FileReader();
            reader.onload = async () => {
              const base64 = reader.result.split(',')[1];
              // For now, just save as text note - full audio storage would need more setup
              await fetch('/api/notes/voice', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ text: '[Voice Note - ' + new Date().toLocaleTimeString() + ']', tags: ['voice'] })
              });
              loadNotes();
              alert('Voice note saved!');
            };
            reader.readAsDataURL(audioBlob);
            stream.getTracks().forEach(track => track.stop());
          };
          
          mediaRecorder.start();
          alert('Recording... Click 🎤 again to stop');
        })
        .catch(e => alert('Mic access denied: ' + e.message));
    }
    
    // Filter by tag
    function filterByTag() {
      const tag = document.getElementById('noteTagFilter').value;
      if (!tag) {
        renderNotes(allNotes);
        return;
      }
      const filtered = allNotes.filter(n => n.tags && n.tags.includes(tag));
      renderNotes(filtered);
    }
    
    // Clip URL Modal
    function showClipUrl() {
      document.getElementById('clipUrlModal').style.display = 'block';
    }
    
    function closeClipUrlModal() {
      document.getElementById('clipUrlModal').style.display = 'none';
      document.getElementById('clipUrl').value = '';
      document.getElementById('clipTags').value = '';
    }
    
    async function clipUrl() {
      const url = document.getElementById('clipUrl').value;
      const tagsInput = document.getElementById('clipTags').value;
      const tags = tagsInput ? tagsInput.split(',').map(t => t.trim()).filter(t => t) : ['web'];
      
      if (!url) {
        alert('Please enter a URL');
        return;
      }
      
      try {
        await fetch('/api/notes/clip', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ url, tags })
        });
        closeClipUrlModal();
        loadNotes();
      } catch(e) {
        alert('Error clipping URL: ' + e.message);
      }
    }
  </script>

  <!-- Clip URL Modal -->
  <div id="clipUrlModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000;">
    <div style="background: var(--bg-secondary); padding: 2rem; border-radius: 1rem; max-width: 500px; margin: 10% auto;">
      <h3 style="color: var(--text-primary); margin-bottom: 1rem;">Clip URL</h3>
      <input type="text" id="clipUrl" placeholder="https://example.com" style="width: 100%; padding: 0.5rem; margin-bottom: 0.5rem; border-radius: 0.5rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary);">
      <input type="text" id="clipTags" placeholder="Tags (comma separated)" style="width: 100%; padding: 0.5rem; margin-bottom: 1rem; border-radius: 0.5rem; background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary);">
      <div style="display: flex; gap: 0.5rem;">
        <button onclick="clipUrl()" class="btn" style="background: var(--accent-purple);">Clip</button>
        <button onclick="closeClipUrlModal()" class="btn" style="background: var(--bg-primary);">Cancel</button>
      </div>
    </div>
  </div>


  <script>
    // Fetch and display cron jobs
    async function loadCronJobs() {
      try {
        const res = await fetch('/api/cronjobs');
        const data = await res.json();
        const container = document.getElementById('cronjobs');
        const jobs = Array.isArray(data) ? data : (data.jobs || []);
        
        // Update timestamp
        document.getElementById('cron-timestamp').textContent = 'Loaded: ' + new Date().toLocaleTimeString();
        
        if (jobs.length > 0) {
          container.innerHTML = jobs.map(job => {
            const schedule = job.schedule?.expr || job.schedule || 'N/A';
            const nextRun = job.state?.nextRunAtMs ? new Date(job.state.nextRunAtMs).toLocaleString() : 'N/A';
            return '<div class="flex justify-between items-center py-2 border-b border-gray-700">' +
              '<span class="font-medium">' + job.name + '</span>' +
              '<span class="text-sm">' + schedule + ' | Next: ' + nextRun + '</span>' +
            '</div>';
          }).join('');
        } else {
          container.innerHTML = '<div class="text-gray-500">No cron jobs configured</div>';
        }
      } catch(e) {
        const cronjobsDiv = document.getElementById('cronjobs');
        if (cronjobsDiv) cronjobsDiv.innerHTML = '<div class="text-red-400">Error loading cron jobs</div>';
      }
    }
    loadCronJobs();

    // Fetch and display sub-agents
    async function loadAgents() {
      try {
        const res = await fetch('/api/agents');
        const agents = await res.json();
        const container = document.getElementById('agents');
        
        if (agents && agents.length > 0) {
          container.innerHTML = '<table style="width:100%;"><tr><th>Agent</th><th>Type</th><th>Description</th></tr>' + 
            agents.map(agent => {
              const typeClass = agent.type === 'main' ? 'text-blue' : 'text-purple';
              return '<tr><td class="font-medium">' + agent.name + '</td><td class="' + typeClass + '">' + agent.type + '</td><td>' + (agent.description || '') + '</td></tr>';
            }).join('') + '</table>';
        } else {
          container.innerHTML = '<div class="text-gray-500">No agents configured</div>';
        }
      } catch(e) {
        const agentsDiv = document.getElementById('agents');
        if (agentsDiv) agentsDiv.innerHTML = '<div class="text-red-400">Error loading agents: ' + e.message + '</div>';
      }
    }
    loadAgents();

    // Load completed tasks
    async function loadCompletedTasks() {
      try {
        const res = await fetch('/api/kanban');
        const data = await res.json();
        const container = document.getElementById('completed-list');
        const completedTasks = (data.tasks || []).filter(t => t.column === 'complete' || t.column === 'completed');
        const completedIdeas = (data.ideas || []).filter(t => t.column === 'complete' || t.column === 'completed');
        const completed = [...completedTasks, ...completedIdeas].sort((a, b) => {
          // Sort by completedAt date, newest first
          const dateA = a.completedAt ? new Date(a.completedAt).getTime() : 0;
          const dateB = b.completedAt ? new Date(b.completedAt).getTime() : 0;
          return dateB - dateA;
        });
        if (completed.length > 0) {
          container.innerHTML = completed.map(t => {
            const completedDate = t.completedAt ? new Date(t.completedAt).toLocaleString() : '';
            return '<div style="padding: 0.75rem; margin-bottom: 0.5rem; background: var(--bg-secondary); border-radius: 0.5rem; border: 1px solid var(--border-color);">' +
              '<div style="font-weight: 600;">' + (t.type === 'idea' ? '💡 ' : '') + t.title + '</div>' +
              (t.description ? '<div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.25rem;">' + t.description + '</div>' : '') +
              (completedDate ? '<div style="font-size: 0.7rem; color: #10b981; margin-top: 0.5rem;">✅ Completed: ' + completedDate + '</div>' : '') +
              (t.completionNotes ? '<div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.25rem; padding: 0.5rem; background: rgba(16,185,129,0.1); border-radius: 0.25rem;">📝 ' + t.completionNotes + '</div>' : '') +
            '</div>';
          }).join('');
        } else {
          container.innerHTML = '<div class="text-center text-gray-500">No completed tasks yet</div>';
        }
      } catch(e) {
        const container = document.getElementById('completed-list');
        if (container) container.innerHTML = '<div class="text-center text-red-400">Error loading tasks</div>';
      }
    }
  </script>
  </div>
