    // Simple doughnut chart
    function drawDoughnut(canvasId, used, free, color) {
      const canvas = document.getElementById(canvasId);
      const ctx = canvas.getContext('2d');
      const size = 150;
      canvas.width = size;
      canvas.height = size;
      const center = size / 2;
      const radius = 55;
      const usedAngle = (used / 100) * 2 * Math.PI || 0;
      
      // Background
      ctx.beginPath();
      ctx.arc(center, center, radius, 0, 2 * Math.PI);
      ctx.strokeStyle = 'rgba(128,128,128,0.2)';
      ctx.lineWidth = 15;
      ctx.stroke();
      
      // Used
      ctx.beginPath();
      ctx.arc(center, center, radius, -Math.PI/2, -Math.PI/2 + usedAngle);
      ctx.strokeStyle = color;
      ctx.lineWidth = 15;
      ctx.lineCap = 'round';
      ctx.stroke();
      
      // Text
      ctx.fillStyle = getComputedStyle(document.body).getPropertyValue('--text-primary');
      ctx.font = 'bold 24px sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText((used || 0) + '%', center, center + 8);
    }

