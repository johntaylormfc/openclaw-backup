        return Promise.race([
          fetch(url),
          new Promise((_, reject) => setTimeout(() => reject(new Error('Timeout')), timeout))
        ]).then(r => r.json()).catch(() => ({ error: 'timeout' }));
      };
      
      Promise.all([
        fetchWithTimeout('/api/all-containers').catch(() => []),
        fetchWithTimeout('/api/nas').catch(() => ({})),
        fetchWithTimeout('/api/vpn').catch(() => ({})),
        fetchWithTimeout('/api/system').catch(() => ({})),
        fetchWithTimeout('/api/tasks').catch(() => ({ tasks: [] })),
        fetchWithTimeout('/api/kanban').catch(() => ({ tasks: [], ideas: [] })),
        fetchWithTimeout('/api/minimax-usage').catch(() => ({}))
      ]).then(([containersData, nasData, vpnData, systemData, todoistData, kanbanData, codingPlanData]) => {
