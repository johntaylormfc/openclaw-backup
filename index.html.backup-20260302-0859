<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ARR Dashboard v3.0</title>
  <style>
    :root {
      --bg-primary: #0f172a;
      --bg-secondary: #1e293b;
      --text-primary: #ffffff;
      --text-secondary: #9ca3af;
      --accent-blue: #60a5fa;
      --accent-purple: #a855f7;
      --accent-green: #4ade80;
      --accent-red: #f87171;
      --accent-yellow: #fbbf24;
      --border-color: rgba(255,255,255,0.1);
    }
    .light-theme {
      --bg-primary: #f1f5f9;
      --bg-secondary: #ffffff;
      --text-primary: #1e293b;
      --text-secondary: #64748b;
      --accent-blue: #2563eb;
      --accent-purple: #7c3aed;
      --accent-green: #16a34a;
      --accent-red: #dc2626;
      --accent-yellow: #d97706;
      --border-color: rgba(0,0,0,0.1);
    }
    body { background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%); min-height: 100vh; color: var(--text-primary); font-family: sans-serif; padding: 20px; transition: all 0.3s; }
    .glass { background: rgba(128,128,128,0.1); backdrop-filter: blur(20px); border: 1px solid var(--border-color); border-radius: 1rem; padding: 1.5rem; margin-bottom: 1.5rem; transition: all 0.3s; }
    h1 { text-align: center; font-size: 2.5rem; background: linear-gradient(to right, var(--accent-blue), var(--accent-purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
    @media (max-width: 900px) { .grid-3 { grid-template-columns: 1fr; } }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid var(--border-color); cursor: pointer; }
    th { color: var(--text-secondary); }
    th:hover { color: var(--accent-blue); }
    .btn { padding: 0.5rem 1rem; border-radius: 0.5rem; font-weight: 600; cursor: pointer; border: none; margin-right: 0.25rem; font-size: 0.75rem; }
    .btn-restart { background: #d97706; color: white; }
    .btn-stop { background: #dc2626; color: white; }
    .btn-start { background: #16a34a; color: white; }
    .btn-logs { background: #2563eb; color: white; }
    .running { color: var(--accent-green); }
    .stopped { color: var(--accent-red); }
    .flex { display: flex; align-items: center; justify-content: space-between; }
    .flex-wrap { flex-wrap: wrap; gap: 0.5rem; }
    .py-2 { padding-top: 0.5rem; padding-bottom: 0.5rem; }
    .font-mono { font-family: monospace; }
    .text-green { color: var(--accent-green); }
    .text-red { color: var(--accent-red); }
    .text-yellow { color: var(--accent-yellow); }
    .text-blue { color: var(--accent-blue); }
    .text-purple { color: var(--accent-purple); }
    .search-box { width: 100%; padding: 0.75rem; border-radius: 0.5rem; border: 1px solid var(--border-color); background: var(--bg-secondary); color: var(--text-primary); font-size: 1rem; margin-bottom: 1rem; }
    .controls { display: flex; gap: 1rem; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; }
    .refresh-select { padding: 0.5rem; border-radius: 0.5rem; border: 1px solid var(--border-color); background: var(--bg-secondary); color: var(--text-primary); }
    .stat-card { text-align: center; padding: 1rem; }
    .stat-value { font-size: 1.5rem; font-weight: bold; }
    .stat-label { color: var(--text-secondary); font-size: 0.875rem; }
    .quick-link { display: inline-block; padding: 0.5rem 1rem; border-radius: 0.5rem; text-decoration: none; color: white; font-weight: 600; text-align: center; min-width: 80px; }
  </style>
</head>
<body>
  <!-- Sidebar Navigation -->
  <div style="display: flex; min-height: 100vh;">
    <div class="sidebar" style="width: 200px; background: var(--bg-secondary); padding: 1rem; border-right: 1px solid var(--border-color); flex-shrink: 0; position: relative; z-index: 100;">
      <h2 style="margin: 0 0 1rem 0; font-size: 1.25rem;">ARR Dashboard</h2>
      <div style="margin-bottom: 0.5rem;">
        <input type="text" id="globalSearch" placeholder="🔍 Search..." 
          style="width: 100%; padding: 0.5rem; border-radius: 0.5rem; border: 1px solid var(--border-color); background: var(--bg-primary); color: var(--text-primary); font-size: 0.875rem;"
          onkeyup="if(event.key==='Enter'||this.value.length>1){performSearch(this.value)}">
        <div id="searchResults" style="display:none; position:absolute; background:var(--bg-secondary); border:1px solid var(--border-color); border-radius:0.5rem; max-height:250px; overflow-y:auto; width:180px; z-index:1000; left:1rem;"></div>
      </div>
      <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <div class="sidebar-menu-item" id="btn-tasks" onclick="showSection('tasks')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">✅ My Tasks</div>
        <div class="sidebar-menu-item" id="btn-kanban" onclick="showSection('kanban')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">📋 Kanban</div>
        <div class="sidebar-menu-item" id="btn-trading" onclick="showSection('trading')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">📈 Trading</div>
        <div class="sidebar-menu-item" id="btn-crypto" onclick="showSection('crypto')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">🪙 Crypto</div>
        <div class="sidebar-menu-item" id="btn-completed" onclick="showSection('completed')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">✅ Completed</div>
        <div class="sidebar-menu-item" id="btn-agents" onclick="showSection('agents')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">🏢 Command Center</div>
        <div class="sidebar-menu-item" id="btn-cron" onclick="showSection('cron')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">⏰ Cron Jobs</div>
        <div class="sidebar-menu-item" id="btn-secondbrain" onclick="showSection('secondbrain')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">🧠 Second Brain</div>
        <div class="sidebar-menu-item" id="btn-containers" onclick="showSection('containers')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">🐳 Containers</div>
        <div class="sidebar-menu-item" id="btn-mcp" onclick="showSection('mcp')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">📦 MCP Servers</div>
        <div class="sidebar-menu-item" id="btn-shortcuts" onclick="showSection('shortcuts')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">🔗 Shortcuts</div>
        <div class="sidebar-menu-item" id="btn-meetings" onclick="showSection('meetings')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">🏢 Board Meetings</div>
        <div class="sidebar-menu-item" id="btn-agent-tasks" onclick="showSection('agent-tasks')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">📋 Agent Tasks</div>
        <div class="sidebar-menu-item" id="btn-xgrowth" onclick="showSection('xgrowth')" style="padding: 0.75rem; cursor: pointer; border-radius: 0.5rem; color: var(--text-secondary);">🐦 X Growth</div>
      </div>
      <button class="btn" style="background: var(--accent-purple); margin-top: auto;" onclick="toggleTheme()">🌗 Theme</button>
    </div>
    
    <!-- Main Content -->
    <div style="flex: 1; padding: 1rem; overflow-y: auto;">
    
    <style>
      .tab-section { display: none !important; }
      .tab-section.active { display: block !important; }
    </style>

    <!-- Kanban Board -->
    <div id="section-kanban" class="tab-section glass" style="display: none;">
      <div id="debug-info" style="background: #1e1e1e; color: #0f0; padding: 0.5rem; font-family: monospace; font-size: 0.75rem; margin-bottom: 0.5rem; border-radius: 0.25rem;"></div>
      <div class="flex" style="margin-bottom: 1rem;">
        <h3>📋 Agent Kanban</h3>
        <button class="btn" style="background: var(--accent-blue); margin-left: auto;" onclick="showAddTask()">+ Add Task</button>
      </div>
      <div id="kanbanBoard" style="display: flex; gap: 0.75rem; overflow-x: auto; padding-bottom: 0.5rem;">
        <!-- Kanban columns rendered by JS -->
      </div>
    </div>

    <div id="section-tasks" class="tab-section active glass" style="display: block;">
    <div class="glass">
      <h3>✅ My Tasks (Todoist)</h3>
      <div id="todoistTasks" style="max-height: 300px; overflow-y: auto;">
        <div style="color: var(--text-secondary);">Loading...</div>
      </div>
    </div>
    </div>

    <!-- Second Brain -->
    <div id="section-secondbrain" class="tab-section glass" style="display: none;">
      <div class="flex" style="margin-bottom: 1rem;">
        <h3>🧠 Second Brain</h3>
        <button class="btn" style="background: var(--accent-green); margin-left: auto;" onclick="showAddNote()">+ Add Note</button>
        <button class="btn" style="background: var(--accent-purple); margin-left: 0.5rem;" onclick="showClipUrl()">+ Clip URL</button>
        <button class="btn" style="background: #f59e0b; margin-left: 0.5rem;" onclick="startVoiceNote()">🎤 Voice</button>
      </div>
      <div style="margin-bottom: 1rem;">
        <input type="text" id="noteSearch" placeholder="Search notes..." style="width: 100%; padding: 0.5rem; border-radius: 0.5rem; background: var(--bg-secondary); border: 1px solid var(--border-color); color: var(--text-primary);" onkeyup="searchNotes()">
      </div>
      <div style="margin-bottom: 1rem;">
        <select id="noteTagFilter" onchange="filterByTag()" style="padding: 0.5rem; border-radius: 0.5rem; background: var(--bg-secondary); border: 1px solid var(--border-color); color: var(--text-primary);">
          <option value="">All Tags</option>
          <option value="business-central">business-central</option>
          <option value="openclaw">openclaw</option>
          <option value="arr">arr</option>
          <option value="voice">voice</option>
          <option value="general">general</option>
        </select>
      </div>
      <div id="notesList" style="max-height: 250px; overflow-y: auto;">
        <div style="color: var(--text-secondary);">Loading...</div>
      </div>
    </div>

    <!-- Cron Jobs -->
    <div id="section-cron" class="tab-section glass" style="display: none;">
      <div class="flex" style="justify-content: space-between; align-items: center;">
        <h3>⏰ Cron Jobs</h3>
        <div id="cron-timestamp" style="font-size: 0.75rem; color: var(--text-secondary);"></div>
      </div>
      <div id="cronjobs" style="color: var(--text-secondary);">Loading...</div>
    </div>

    <!-- Command Center -->
    <div id="section-agents" class="tab-section glass" style="display: none;">
      <div class="flex" style="margin-bottom: 1rem;">
        <h3>🏢 Command Center</h3>
        <button class="btn" style="background: var(--accent-blue); margin-left: auto;" onclick="loadCommandCenter()">🔄 Refresh</button>
      </div>
      <div id="agent-cards" class="grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));"></div>
      <div style="margin-top: 2rem;">
        <h4 style="margin-bottom: 1rem;">🤖 Board Meetings</h4>
        <div id="meetings-list"></div>
      </div>
      
    </div>

    <!-- Tasks Overview -->
    <div id="section-agent-tasks" class="tab-section glass" style="display: none;">
      <div class="flex" style="margin-bottom: 1rem;">
        <h3>📋 Agent Tasks</h3>
        <button class="btn" style="background: var(--accent-blue); margin-left: auto;" onclick="loadTasksOverview()">🔄 Refresh</button>
      </div>
      <div id="tasks-overview" style="color: var(--text-secondary);">Loading...</div>
    </div>

    <!-- Completed Tasks -->
    <div id="section-completed" class="tab-section glass" style="display: none;">
      <h3>✅ Completed Tasks</h3>
      <div id="completed-list" style="color: var(--text-secondary);">Loading...</div>
    </div>

    <!-- Containers Table -->
    <div id="section-containers" class="tab-section glass" style="display: none;">
      <h2>Containers (Live)</h2>
      <div class="controls">
        <input type="text" class="search-box" id="searchBox" placeholder="🔍 Search containers..." onkeyup="filterContainers()">
        <select class="refresh-select" id="refreshRate" onchange="setRefreshRate()">
          <option value="5000">5 sec</option>
          <option value="10000" selected>10 sec</option>
          <option value="30000">30 sec</option>
          <option value="60000">1 min</option>
          <option value="0">Paused</option>
        </select>
        <span style="color: var(--text-secondary);" id="lastUpdate">Last update: --</span>
      </div>
      <table>
        <thead>
          <tr onclick="sortTable(event)">
            <th data-sort="name">Name ↕</th>
            <th data-sort="status">Status ↕</th>
            <th data-sort="cpu">CPU% ↕</th>
            <th data-sort="mem">Mem% ↕</th>
            <th data-sort="ports">Ports ↕</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="containers"></tbody>
      </table>
    </div>

    <!-- Trading Section -->
    <div id="section-trading" class="tab-section glass" style="display: none;">
      <div class="flex" style="margin-bottom: 1rem;">
        <h3>📈 Stock Trading Bot</h3>
        <button class="btn" style="background: var(--accent-blue); margin-left: auto;" onclick="loadTradingData()">🔄 Refresh</button>
      </div>
      <div class="grid" style="margin-bottom: 1rem;">
        <div class="stat-card" style="background: var(--bg-secondary); border-radius: 0.5rem; padding: 1rem;">
          <div class="stat-value" id="trading-portfolio">$0</div>
          <div class="stat-label">Portfolio Value</div>
        </div>
        <div class="stat-card" style="background: var(--bg-secondary); border-radius: 0.5rem; padding: 1rem;">
          <div class="stat-value" id="trading-cash">$0</div>
          <div class="stat-label">Cash</div>
        </div>
        <div class="stat-card" style="background: var(--bg-secondary); border-radius: 0.5rem; padding: 1rem;">
          <div class="stat-value" id="trading-pnl">$0</div>
          <div class="stat-label">Total P&L</div>
        </div>
      </div>
      <div id="trading-updated" style="color: var(--text-secondary); font-size: 0.75rem; margin-top: 0.5rem;"></div>
      <h4>Current Positions</h4>
      <table id="trading-positions">
        <thead><tr><th>Symbol</th><th>Shares</th><th>Avg Cost</th><th>Current</th><th>P&L</th><th>P&L %</th></tr></thead>
        <tbody></tbody>
      </table>
      <h4 style="margin-top: 1rem;">Recent Trades</h4>
      <table id="trading-trades">
        <thead><tr><th>Time</th><th>Symbol</th><th>Side</th><th>Shares</th><th>Price</th></tr></thead>
        <tbody></tbody>
      </table>
    </div>

    <!-- Crypto Section -->
    <div id="section-crypto" class="tab-section glass" style="display: none;">
      <div class="flex" style="margin-bottom: 1rem; justify-content: space-between;">
        <h3>🪙 Crypto Trading Bot</h3>
        <div style="text-align: right;">
          <button class="btn" style="background: var(--accent-blue);" onclick="loadCryptoData()">🔄 Refresh</button>
          <div id="crypto-timestamp" style="font-size: 0.7rem; color: var(--text-secondary); margin-top: 0.25rem;"></div>
        </div>
      </div>
      <div class="grid" style="margin-bottom: 1rem;">
        <div class="stat-card" style="background: var(--bg-secondary); border-radius: 0.5rem; padding: 1rem;">
          <div class="stat-value" id="crypto-portfolio">$0</div>
          <div class="stat-label">Portfolio Value</div>
        </div>
        <div class="stat-card" style="background: var(--bg-secondary); border-radius: 0.5rem; padding: 1rem;">
          <div class="stat-value" id="crypto-cash">$0</div>
          <div class="stat-label">Cash</div>
        </div>
        <div class="stat-card" style="background: var(--bg-secondary); border-radius: 0.5rem; padding: 1rem;">
          <div class="stat-value" id="crypto-exposure">0%</div>
          <div class="stat-label">Exposure</div>
        </div>
      </div>
      <div id="crypto-updated" style="color: var(--text-secondary); font-size: 0.75rem; margin-top: 0.5rem;"></div>
      <h4>Current Positions</h4>
      <table id="crypto-positions">
        <thead><tr><th>Pair</th><th>Qty</th><th>Entry</th><th>Current</th><th>P&L</th></tr></thead>
        <tbody></tbody>
      </table>
      <h4>Recent Transactions</h4>
      <table id="crypto-transactions">
        <thead><tr><th>Time</th><th>Pair</th><th>Action</th><th>Price</th><th>Qty</th></tr></thead>
        <tbody></tbody>
      </table>
    </div>

    <!-- Shortcuts Section -->
    <div id="section-shortcuts" class="tab-section glass" style="display: none;">
      <h3>🔗 Quick Links</h3>
      <div id="quickLinks"></div>
    </div>

    <!-- Board Meetings Section -->
    <div id="section-meetings" class="tab-section glass" style="display: none;">
      <h3>🏢 Board Meetings</h3>
      <div id="meetings-content" style="color: var(--text-secondary);">Loading...</div>
    </div>

    <!-- X Growth Section -->
    <div id="section-xgrowth" class="tab-section glass" style="display: none;">
      <div class="flex" style="justify-content: space-between; align-items: center;">
        <h3>🐦 X Growth Dashboard</h3>
        <div id="x-timestamp" style="font-size: 0.75rem; color: var(--text-secondary);"></div>
      </div>
      
      <!-- Key Metrics -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
        <div class="stat-card glass">
          <div class="stat-value" id="x-followers">-</div>
          <div class="stat-label">Followers</div>
        </div>
        <div class="stat-card glass">
          <div class="stat-value" id="x-following">-</div>
          <div class="stat-label">Following</div>
        </div>
        <div class="stat-card glass">
          <div class="stat-value" id="x-posts">-</div>
          <div class="stat-label">Total Posts</div>
        </div>
        <div class="stat-card glass">
          <div class="stat-value" id="x-replies">-</div>
          <div class="stat-label">Total Replies</div>
        </div>
      </div>
      
      <!-- Daily Limits -->
      <div style="background: var(--bg-secondary); padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem;">
        <h4 style="margin: 0 0 0.5rem 0;">📊 Phase A Goals - Day <span id="x-day-count">3</span> (Cumulative: daily × days)</h4>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem; font-size: 0.875rem;">
          <div>Posts: <span id="x-limit-posts">6</span></div>
          <div>Replies: <span id="x-limit-replies">12</span></div>
          <div>Follows: <span id="x-limit-follows">9</span></div>
          <div>Likes: <span id="x-limit-likes">48</span></div>
        </div>
        <div style="margin-top: 0.5rem; font-size: 0.75rem; color: var(--text-secondary);">
          Used: <span id="x-used-posts">0</span>/2 posts, <span id="x-used-replies">0</span>/4 replies
        </div>
      </div>
      
      <!-- Targets with Progress Bars -->
      <div style="background: var(--bg-secondary); padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem;">
        <h4 style="margin: 0 0 1rem 0;">🎯 Progress to Goals</h4>
        
        <!-- Followers Progress -->
        <div style="margin-bottom: 1rem;">
          <div style="display: flex; justify-content: space-between; font-size: 0.875rem; margin-bottom: 0.25rem;">
            <span>Followers (1,000 goal)</span>
            <span id="x-followers-progress">1</span>
            <span id="x-target-1k">0%</span>
          </div>
          <div style="background: var(--bg-primary); height: 12px; border-radius: 6px; overflow: hidden;">
            <div id="x-followers-bar" style="background: var(--accent-green); height: 100%; width: 0.1%; transition: width 0.5s;"></div>
          </div>
        </div>
        
        <!-- Posts Progress -->
        <div style="margin-bottom: 1rem;">
          <div style="display: flex; justify-content: space-between; font-size: 0.875rem; margin-bottom: 0.25rem;">
            <span>Posts (Goal: <span id="x-posts-goal">2</span>)</span>
            <span id="x-posts-progress">0</span>
          </div>
          <div style="background: var(--bg-primary); height: 12px; border-radius: 6px; overflow: hidden;">
            <div id="x-posts-bar" style="background: var(--accent-blue); height: 100%; width: 0%; transition: width 0.5s;"></div>
          </div>
        </div>
        
        <!-- Replies Progress -->
        <div style="margin-bottom: 1rem;">
          <div style="display: flex; justify-content: space-between; font-size: 0.875rem; margin-bottom: 0.25rem;">
            <span>Replies (Goal: <span id="x-replies-goal">12</span>)</span>
            <span id="x-replies-progress">0</span>
          </div>
          <div style="background: var(--bg-primary); height: 12px; border-radius: 6px; overflow: hidden;">
            <div id="x-replies-bar" style="background: var(--accent-purple); height: 100%; width: 0%; transition: width 0.5s;"></div>
          </div>
        </div>
        
        <!-- Likes Progress -->
        <div style="margin-bottom: 1rem;">
          <div style="display: flex; justify-content: space-between; font-size: 0.875rem; margin-bottom: 0.25rem;">
            <span>Likes (Goal: <span id="x-likes-goal">16</span>)</span>
            <span id="x-likes-progress">0</span>
          </div>
          <div style="background: var(--bg-primary); height: 12px; border-radius: 6px; overflow: hidden;">
            <div id="x-likes-bar" style="background: var(--accent-red); height: 100%; width: 0%; transition: width 0.5s;"></div>
          </div>
        </div>
        
        <!-- Follows Progress -->
        <div style="margin-bottom: 1rem;">
          <div style="display: flex; justify-content: space-between; font-size: 0.875rem; margin-bottom: 0.25rem;">
            <span>Follows (Goal: <span id="x-follows-goal">3</span>)</span>
            <span id="x-follows-progress">0</span>
          </div>
          <div style="background: var(--bg-primary); height: 12px; border-radius: 6px; overflow: hidden;">
            <div id="x-follows-bar" style="background: var(--accent-yellow); height: 100%; width: 0%; transition: width 0.5s;"></div>
          </div>
        </div>
      </div>
      
      <!-- Line Charts -->
      <div id="x-charts" style="background: var(--bg-secondary); padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem;">
        <h4 style="margin: 0 0 1rem 0;">📈 Progress Over Time</h4>
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
          <div>
            <div style="font-size: 0.75rem; margin-bottom: 0.5rem; text-align: center;">Posts</div>
            <canvas id="chart-posts" width="400" height="200" style="width: 100%; height: 100px;"></canvas>
          </div>
          <div>
            <div style="font-size: 0.75rem; margin-bottom: 0.5rem; text-align: center;">Replies</div>
            <canvas id="chart-replies" width="400" height="200" style="width: 100%; height: 100px;"></canvas>
          </div>
          <div>
            <div style="font-size: 0.75rem; margin-bottom: 0.5rem; text-align: center;">Likes</div>
            <canvas id="chart-likes" width="400" height="200" style="width: 100%; height: 100px;"></canvas>
          </div>
          <div>
            <div style="font-size: 0.75rem; margin-bottom: 0.5rem; text-align: center;">Follows</div>
            <canvas id="chart-follows" width="400" height="200" style="width: 100%; height: 100px;"></canvas>
          </div>
        </div>
        <div style="display: flex; justify-content: center; gap: 1rem; margin-top: 0.5rem; font-size: 0.7rem;">
          <span style="color: var(--accent-blue);">── Actual (cumulative)</span>
          <span style="color: var(--text-secondary);">── Target</span>
        </div>
      </div>
      
      <!-- Quick Actions -->
      <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
        <button class="btn" style="background: var(--accent-blue);" onclick="loadXGrowth()">🔄 Refresh</button>
      </div>
      
      <div id="xgrowth-content" style="color: var(--text-secondary);">
        <p style="color: var(--text-secondary);">Click refresh to load data...</p>
      </div>
    </div>

    <!-- MCP Servers Section -->
    <div id="section-mcp" class="tab-section glass" style="display: none;">
      <h3>📦 MCP Servers</h3>
      <div id="mcp-content" style="color: var(--text-secondary);">Loading...</div>
    </div>

    <!-- Add Task Modal -->
    <div id="addTaskModal" class="fixed inset-0 bg-black/80 hidden items-center justify-center z-50" style="display: none;">
      <div class="glass rounded-2xl p-6" style="width: 400px; max-width: 90vw;">
        <h3 class="text-xl font-bold mb-4">Add New Task</h3>
        <input type="text" id="newTaskTitle" placeholder="Task title" style="width: 100%; padding: 0.5rem; margin-bottom: 0.5rem; border-radius: 0.5rem; border: 1px solid var(--border-color); background: var(--bg-secondary); color: var(--text-primary);">
        <textarea id="newTaskDesc" placeholder="Description (optional)" rows="3" style="width: 100%; padding: 0.5rem; margin-bottom: 0.5rem; border-radius: 0.5rem; border: 1px solid var(--border-color); background: var(--bg-secondary); color: var(--text-primary);"></textarea>
        <select id="newTaskColumn" style="width: 100%; padding: 0.5rem; margin-bottom: 1rem; border-radius: 0.5rem; border: 1px solid var(--border-color); background: var(--bg-secondary); color: var(--text-primary);">
          <option value="idea">💡 Idea</option>
          <option value="backlog" selected>Backlog</option>
        </select>
        <div style="display: flex; gap: 0.5rem;">
          <button class="btn" style="background: var(--accent-green); flex: 1;" onclick="addTask()">Add</button>
          <button class="btn" style="background: var(--accent-red); flex: 1;" onclick="hideAddTask()">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    let containers = [];
    let refreshInterval = 10000;
    let intervalId = null;
    let sortCol = 'name';
    let sortAsc = true;
    let theme = localStorage.getItem('theme') || 'dark';
    
    // Load X Growth data on page load
    document.addEventListener('DOMContentLoaded', function() {
      loadXGrowth();
    });

    // Load shortcuts/quick links
    function loadQuickLinks() {
      const div = document.getElementById('quickLinks');
      if (div) {
        div.innerHTML = quickLinks.map(q => {
          const url = q.path ? `http://192.168.1.146:${q.port}${q.path}` : `http://192.168.1.146:${q.port}`;
          return '<a href="' + url + '" target="_blank" class="quick-link" style="display:inline-block;padding:0.5rem 1rem;background:'+q.color+';color:white;border-radius:0.5rem;text-decoration:none;margin:0.25rem;">' + q.name + '</a>';
        }).join('');
      }
    }

    // Quick action links
    const quickLinks = [
      { name: 'Sonarr', port: 8989, color: '#16a34a' },
      { name: 'Radarr', port: 7878, color: '#2563eb' },
      { name: 'Plex', port: 32400, path: '/web', color: '#db2777' },
      { name: 'Grafana', port: 3000, color: '#9333ea' },
      { name: 'Jellyfin', port: 8096, color: '#0ea5e9' },
      { name: 'Overseerr', port: 5056, color: '#f59e0b' },
      { name: 'SABnzbd', port: 8080, color: '#22c55e' },
      { name: 'Portainer', port: 9000, color: '#3b82f6' },
      { name: 'Homepage', port: 3004, color: '#6366f1' },
      { name: 'Tautulli', port: 8181, color: '#ec4899' },
      { name: 'Transmission', port: 30800, path: '/transmission/web/', color: '#eab308' },
    ];

    function initTheme() {
      if (theme === 'light') document.body.classList.add('light-theme');
    }

    async function loadNotes() {
      try {
        const res = await fetch('/api/notes');
        if (!res.ok) throw new Error('API error: ' + res.status);
        const data = await res.json();
        allNotes = data.notes || [];
        renderNotes(allNotes);
      } catch(e) {
        console.error('Notes load error:', e);
        const notesList = document.getElementById('notesList');
        if (notesList) notesList.innerHTML = '<div style="color: var(--text-secondary);">Error loading notes - click to retry</div>';
        if (notesList) notesList.onclick = loadNotes;
      }
    }



    async function loadMcpServers() {
      try {
        const res = await fetch('/api/mcp');
        const servers = await res.json();
        let html = '<table><thead><tr><th>Server</th><th>Status</th><th>Tools</th><th>Description</th></tr></thead><tbody>';
        servers.forEach(s => {
          const status = s.status === 'ok' ? '<span style="color:#4ade80">✅</span>' : '<span style="color:#f87171">❌</span>';
          html += '<tr><td>' + s.name + '</td><td>' + status + '</td><td>' + (s.tools || '-') + '</td><td>' + (s.description || '') + '</td></tr>';
        });
        html += '</tbody></table>';
        document.getElementById('mcp-content').innerHTML = html;
      } catch(e) {
        document.getElementById('mcp-content').innerHTML = '<div style="color:var(--text-secondary)">Error loading MCP servers</div>';
      }
    }

    // Command Center functions
    let ccInterval = null;
    let tradingInterval = null;
    let cryptoInterval = null;
    
    async function loadCommandCenter() {
      await Promise.all([loadAgentsCC(), loadMeetingsCC()]);
    }
    
    async function loadMeetingsCC() {
      try {
        const res = await fetch('/api/command-center/meetings');
        let meetings = await res.json();
        
        // Sort by date, newest first
        meetings.sort((a, b) => new Date(b.startedAt) - new Date(a.startedAt));
        
        let html = '';
        if (meetings && meetings.length > 0) {
          meetings.slice(0, 5).forEach(m => {
            const date = m.startedAt ? new Date(m.startedAt).toLocaleString() : '';
            const participants = Array.isArray(m.participants) ? m.participants.join(', ') : '';
            const subtasks = Array.isArray(m.subtasks) ? m.subtasks : [];
            const statusColor = m.status === 'completed' ? '#4ade80' : '#fbbf24';
            const isComplete = m.status === 'completed';
            
            let htmlContent = '<div style="padding:0.75rem;margin:0.5rem 0;background:var(--bg-primary);border-radius:0.5rem;">' +
              '<div style="display:flex;justify-content:space-between;align-items:center">' +
              '<span style="font-weight:bold">'+(m.taskTitle || 'Board Meeting')+'</span>' +
              '<span style="font-size:0.7rem;background:'+statusColor+';padding:0.2rem 0.5rem;border-radius:1rem">'+m.status+'</span></div>' +
              '<div style="font-size:0.75rem;color:var(--text-secondary);margin-top:0.25rem">📅 '+date+'</div>' +
              '<div style="font-size:0.75rem;color:var(--text-secondary)">👥 '+participants+'</div>';
            
            if (isComplete && m.transcript) {
              // Show first part of transcript (the discussion)
              const transcript = m.transcript || '';
              htmlContent += '<div style="margin-top:0.5rem;padding:0.5rem;background:var(--bg-secondary);border-radius:0.25rem;font-size:0.7rem;max-height:500px;overflow-y:auto;word-wrap:break-word"><strong>💬 Discussion:</strong><br/>'+transcript.replace(/\n/g, '<br/>')+'</div>';
            }
            if (isComplete && m.plan) {
              // Show the outcome/plan prominently
              htmlContent += '<div style="margin-top:0.5rem;padding:0.75rem;background:linear-gradient(135deg, #10b981, #059669);border-radius:0.5rem;font-size:0.8rem;color:white;font-weight:bold"><strong>🎯 OUTCOME:</strong><br/>'+m.plan.replace(/\n/g, '<br/>')+'</div>';
            }
            if (isComplete && subtasks && subtasks.length > 0) {
              htmlContent += '<div style="margin-top:0.5rem;font-size:0.7rem"><strong>✅ Assigned Tasks:</strong>';
              subtasks.forEach(s => {
                htmlContent += '<div style="margin:0.25rem 0;padding:0.25rem;background:var(--bg-secondary);border-radius:0.25rem">• <strong>'+s.agentId+':</strong> '+s.task+'</div>';
              });
              htmlContent += '</div>';
            } else if (isComplete) {
              htmlContent += '<div style="margin-top:0.5rem;font-size:0.7rem;color:var(--text-secondary)">No subtasks recorded</div>';
            } else if (!isComplete) {
              htmlContent += '<button class="btn" style="background:var(--accent-blue);margin-top:0.5rem;font-size:0.7rem;padding:0.4rem" onclick="event.stopPropagation();completeMeeting(\''+m.id+'\')">✅ Complete Meeting</button>';
            }
            
            // Delete button for all meetings
            htmlContent += '<button class="btn" style="background:var(--accent-red);margin-top:0.5rem;font-size:0.7rem;padding:0.4rem;margin-left:0.25rem" onclick="event.stopPropagation();deleteMeeting(\''+m.id+'\')">🗑️ Delete</button>';
            
            htmlContent += '</div>';
            html += htmlContent;
          });
        } else {
          html = '<div style="color:var(--text-secondary);padding:0.5rem">No board meetings yet</div>';
        }
        document.getElementById('meetings-content').innerHTML = html;
      } catch(e) {
        document.getElementById('meetings-content').innerHTML = '<div style="color:var(--text-secondary)">Error loading meetings</div>';
      }
    }
    
    // Load Tasks Overview - shows agent tasks from board meetings
    async function loadTasksOverview() {
      try {
        const res = await fetch('/api/command-center/tasks');
        const tasks = await res.json();
        
        // Get agent info
        const agentsRes = await fetch('/api/command-center/agents');
        const agents = await agentsRes.json();
        const agentMap = {};
        agents.forEach(a => agentMap[a.id] = a.name);
        
        // Group by status
        const inProgress = tasks.filter(t => t.status === 'in-progress');
        const pending = tasks.filter(t => t.status === 'pending');
        const completed = tasks.filter(t => t.status === 'completed').slice(0, 10); // Recent only
        
        let html = '';
        
        // In Progress
        if (inProgress.length > 0) {
          html += '<h4 style="color: #fbbf24; margin: 1rem 0 0.5rem 0;">📋 In Progress (' + inProgress.length + ')</h4>';
          inProgress.forEach(task => {
            const agentName = agentMap[task.agentId] || task.agentId;
            html += '<div class="glass" style="padding: 1rem; margin-bottom: 0.5rem; border-left: 3px solid #fbbf24;">';
            html += '<div style="font-weight: 600;">' + task.title + '</div>';
            html += '<div style="font-size: 0.75rem; color: #60a5fa; margin-top: 0.25rem;">🤖 ' + agentName + '</div>';
            if (task.description) {
              html += '<div style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.25rem;">' + task.description.substring(0, 80) + '</div>';
            }
            html += '</div>';
          });
        }
        
        // Pending
        if (pending.length > 0) {
          html += '<h4 style="color: #60a5fa; margin: 1rem 0 0.5rem 0;">📝 Waiting (' + pending.length + ')</h4>';
          pending.forEach(task => {
            const agentName = agentMap[task.agentId] || task.agentId;
            html += '<div class="glass" style="padding: 1rem; margin-bottom: 0.5rem; border-left: 3px solid #60a5fa;">';
            html += '<div style="font-weight: 600;">' + task.title + '</div>';
            html += '<div style="font-size: 0.75rem; color: #60a5fa; margin-top: 0.25rem;">🤖 ' + agentName + '</div>';
            html += '</div>';
          });
        }
        
        // Recent Completed
        if (completed.length > 0) {
          html += '<h4 style="color: #10b981; margin: 1rem 0 0.5rem 0;">✅ Recent Completed (' + completed.length + ')</h4>';
          completed.forEach(task => {
            const agentName = agentMap[task.agentId] || task.agentId;
            const time = task.completedAt ? new Date(task.completedAt).toLocaleTimeString() : '';
            html += '<div class="glass" style="padding: 0.75rem; margin-bottom: 0.25rem; border-left: 3px solid #10b981; opacity: 0.7;">';
            html += '<div style="font-size: 0.85rem;">' + task.title.substring(0, 40) + '</div>';
            html += '<div style="font-size: 0.7rem; color: var(--text-secondary);">🤖 ' + agentName + ' • ' + time + '</div>';
            html += '</div>';
          });
        }
        
        if (!html) {
          html = '<div style="color: var(--text-secondary); padding: 1rem;">No agent tasks yet. Pick a backlog task to trigger a board meeting!</div>';
        }
        
        document.getElementById('tasks-overview').innerHTML = html;
      } catch(e) {
        document.getElementById('tasks-overview').innerHTML = '<div style="color: var(--text-secondary);">Error loading tasks: ' + e.message + '</div>';
      }
    }
    
    async function loadAgentsCC() {
      try {
        const res = await fetch('/api/command-center/agents');
        const agents = await res.json();
        
        // Also fetch all tasks
        let allTasks = [];
        try {
          const tasksRes = await fetch('/api/command-center/tasks');
          allTasks = await tasksRes.json();
        } catch(e) {}
        
        let html = '';
        for (const agent of agents) {
          const statusColor = agent.status === 'online' ? '#4ade80' : agent.status === 'busy' ? '#fbbf24' : '#6b7280';
          const lastActive = agent.lastActive ? new Date(agent.lastActive).toLocaleString() : 'Never';
          const caps = Array.isArray(agent.capabilities) ? agent.capabilities : [];
          const currentTask = agent.currentTask || '';
          
          // Get tasks for this agent
          const agentTasks = allTasks.filter(t => t.agentId === agent.id) || [];
          const pastTasks = agentTasks.filter(t => t.status === 'completed').slice(0, 3);
          const presentTasks = agentTasks.filter(t => t.status === 'in-progress');
          const futureTasks = agentTasks.filter(t => t.status === 'pending').slice(0, 3);
          
          // Build task summary
          let taskHtml = '';
          
          // Future tasks (pending)
          if (futureTasks.length > 0) {
            taskHtml += '<div style="margin-top:0.5rem"><span style="color:#60a5fa;font-size:0.7rem">🔜 UPCOMING:</span>';
            futureTasks.forEach(t => {
              taskHtml += '<div style="font-size:0.7rem;padding:0.25rem;background:#1e3a5f;border-radius:0.25rem;margin:0.25rem 0">'+t.title.substring(0,35)+'</div>';
            });
            taskHtml += '</div>';
          }
          
          // Current tasks (in-progress)
          if (presentTasks.length > 0) {
            taskHtml += '<div style="margin-top:0.5rem"><span style="color:#fbbf24;font-size:0.7rem">📋 CURRENT:</span>';
            presentTasks.forEach(t => {
              taskHtml += '<div style="font-size:0.7rem;padding:0.25rem;background:var(--accent-purple);border-radius:0.25rem;margin:0.25rem 0">'+t.title.substring(0,35)+'</div>';
            });
            taskHtml += '</div>';
          }
          
          // Recent completed
          if (pastTasks.length > 0) {
            taskHtml += '<div style="margin-top:0.5rem"><span style="color:#10b981;font-size:0.7rem">✅ RECENT:</span>';
            pastTasks.forEach(t => {
              const time = t.completedAt ? new Date(t.completedAt).toLocaleTimeString() : '';
              taskHtml += '<div style="font-size:0.65rem;padding:0.25rem;margin:0.25rem 0;color:var(--text-secondary)">'+t.title.substring(0,30)+' - '+time+'</div>';
            });
            taskHtml += '</div>';
          }
          
          // Fetch activity for this agent
          let activityHtml = '';
          try {
            const actRes = await fetch('/api/command-center/agents/'+agent.id+'/activity?limit=5');
            const actData = await actRes.json();
            if (actData.activities && actData.activities.length > 0) {
              activityHtml = '<div style="margin-top:0.5rem;padding-top:0.5rem;border-top:1px solid var(--border)">';
              actData.activities.slice(0,3).forEach(a => {
                const icon = a.action && a.action.toLowerCase().includes('complete') ? '✅' : '📋';
                const time = a.timestamp ? new Date(a.timestamp).toLocaleTimeString() : '';
                activityHtml += '<div style="font-size:0.65rem;color:var(--text-secondary);margin:0.2rem 0">'+icon+' '+a.action.substring(0,25)+' - '+time+'</div>';
              });
              activityHtml += '</div>';
            }
          } catch(e) {}
          
          html += '<div class="glass" style="cursor:pointer; padding:1rem;" onclick="showAgentDetailCC(\''+agent.id+'\')">' +
            '<div class="flex"><h4 style="margin:0">'+agent.name+'</h4>' +
            '<span style="display:inline-flex;align-items:center;gap:0.25rem">' +
            '<span style="width:8px;height:8px;border-radius:50%;background:'+statusColor+';display:inline-block"></span>' +
            '<span style="font-size:0.75rem;color:'+statusColor+'">'+agent.status+'</span></span></div>' +
            (currentTask ? '<div style="background:var(--accent-purple);padding:0.4rem;border-radius:0.5rem;margin:0.5rem 0;font-size:0.8rem">📋 '+currentTask.substring(0,45)+(currentTask.length>45?'...':'')+'</div>' : '') +
            taskHtml +
            '<div style="color:var(--text-secondary);font-size:0.875rem;margin:0.5rem 0">'+(agent.role || 'No role')+'</div>' +
            '<div style="font-size:0.75rem;color:var(--text-secondary)">' +
            '<span style="color:var(--accent-blue)">'+(agent.model || 'minimax/minimax-m2.5')+'</span> • Last active: '+lastActive+'</div>' +
            '<div style="margin-top:0.5rem;display:flex;flex-wrap:wrap;gap:0.25rem">' +
            caps.slice(0,3).map(c => '<span style="background:var(--bg-primary);padding:0.125rem 0.5rem;border-radius:1rem;font-size:0.7rem">'+c+'</span>').join('') +
            (caps.length > 3 ? '<span style="font-size:0.7rem;color:var(--text-secondary)">+'+(caps.length-3)+' more</span>' : '') + '</div>' +
            activityHtml +
            '</div>';
        }
        
        document.getElementById('agent-cards').innerHTML = html || '<div style="color:var(--text-secondary)">No agents found</div>';
      } catch(e) {
        document.getElementById('agent-cards').innerHTML = '<div style="color:var(--text-secondary)">Error: '+e.message+'</div>';
      }
    }
    
    async function loadDecisionsCC() {
      try {
        const res = await fetch('/api/command-center/decisions');
        const decisions = await res.json();
        
        let html = '<table style="width:100%"><thead><tr><th>Date</th><th>Question</th><th>Decision</th><th>Agents</th></tr></thead><tbody>';
        decisions.forEach(d => {
          const agents = Array.isArray(d.agentsConsulted) ? d.agentsConsulted.join(', ') : '';
          html += '<tr><td>'+(d.date || '')+'</td><td>'+(d.question || '')+'</td><td>'+(d.decision || '')+'</td><td style="font-size:0.75rem;color:var(--text-secondary)">'+agents+'</td></tr>';
        });
        html += '</tbody></table>' + (decisions.length === 0 ? '<div style="color:var(--text-secondary)">No decisions yet</div>' : '');
        
        document.getElementById('decisions-list').innerHTML = html;
      } catch(e) {
        document.getElementById('decisions-list').innerHTML = '<div style="color:var(--text-secondary)">Error loading decisions</div>';
      }
    }
    
    async function showAgentDetailCC(agentId) {
      try {
        const [agentRes, activityRes, tasksRes] = await Promise.all([
          fetch('/api/command-center/agents/' + agentId),
          fetch('/api/command-center/agents/' + agentId + '/activity?limit=1'),
          fetch('/api/command-center/agents/' + agentId + '/tasks')
        ]);
        const agent = await agentRes.json();
        const activities = await activityRes.json();
        const tasksData = await tasksRes.json();
        
        const statusColor = agent.status === 'online' ? '#4ade80' : agent.status === 'busy' ? '#fbbf24' : '#6b7280';
        
        // Build tasks section
        let tasksHtml = '';
        if (tasksData.present && tasksData.present.length > 0) {
          tasksHtml += '<div style="margin-bottom:1rem"><strong style="color:#fbbf24">📋 Current Tasks:</strong></div>';
          tasksData.present.forEach(t => {
            tasksHtml += '<div style="padding:0.5rem;background:var(--accent-purple);border-radius:0.5rem;margin-bottom:0.5rem;font-size:0.8rem">'+t.title+'</div>';
          });
        }
        if (tasksData.future && tasksData.future.length > 0) {
          tasksHtml += '<div style="margin-bottom:0.5rem"><strong style="color:var(--text-secondary)">⏳ Pending Tasks:</strong></div>';
          tasksData.future.forEach(t => {
            tasksHtml += '<div style="padding:0.25rem;font-size:0.75rem;color:var(--text-secondary)">• '+t.title+'</div>';
          });
        }
        if (tasksData.past && tasksData.past.length > 0) {
          tasksHtml += '<div style="margin-bottom:0.5rem"><strong style="color:#10b981">✅ Recent Completed:</strong></div>';
          tasksData.past.slice(0, 5).forEach(t => {
            const time = t.completedAt ? new Date(t.completedAt).toLocaleDateString() : '';
            tasksHtml += '<div style="padding:0.25rem;font-size:0.7rem;color:var(--text-secondary)">• '+t.title.substring(0,40)+' ('+time+')</div>';
          });
        }
        if (!tasksHtml) tasksHtml = '<div style="color:var(--text-secondary)">No tasks</div>';
        
        let html = '<div class="glass" style="position:fixed;top:0;right:0;width:400px;height:100vh;overflow-y:auto;z-index:1000;margin:0;border-radius:0;padding:1.5rem;">' +
          '<div class="flex" style="margin-bottom:1rem;"><h3 style="margin:0">'+agent.name+'</h3>' +
          '<button class="btn" style="background:var(--accent-red)" onclick="closeAgentDetailCC()">✕</button></div>' +
          '<div style="margin-bottom:1rem"><span style="display:inline-flex;align-items:center;gap:0.5rem"><span style="width:10px;height:10px;border-radius:50%;background:'+statusColor+'"></span><span style="color:'+statusColor+'">'+agent.status+'</span></span></div>' +
          '<div style="color:var(--text-secondary);margin-bottom:1rem"><strong>Role:</strong> '+(agent.role || 'N/A')+'</div>' +
          '<div style="margin-bottom:1rem"><strong>Model:</strong> <span style="color:var(--accent-blue)">'+agent.model+'</span></div>' +
          '<div style="margin-bottom:1rem"><strong>Last Active:</strong> '+(agent.lastActive ? new Date(agent.lastActive).toLocaleString() : 'Never')+'</div>' +
