      const transcript = prompt('Enter discussion summary:') || 'Discussed and agreed on plan.';
      
      const subtasksStr = prompt('Enter subtasks (format: agentId: task; agentId: task):');
      const subtasks = [];
      if (subtasksStr) {
        subtasksStr.split(';').forEach(s => {
          const [agentId, task] = s.split(':').map(x => x.trim());
          if (agentId && task) subtasks.push({agentId, task});
        });
      }
      
      try {
        const res = await fetch('/api/command-center/meetings/' + meetingId + '/complete', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({transcript, plan, subtasks})
        });
        const data = await res.json();
        if (data.success) {
          alert('Meeting completed! Decision recorded.');
          loadMeetingsCC();
          loadDecisionsCC();
        }
      } catch(e) {
        alert('Error: ' + e.message);
      }
    }
    
