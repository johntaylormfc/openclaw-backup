#!/usr/bin/env python3
"""BC Workflows - Plain English Intent Router"""

import os
import re
import sys
import json
import subprocess
from pathlib import Path

# Configuration
AL_FACTORY = os.path.expanduser("~/.openclaw/workspace/al_factory")
INBOX_DIRS = [
    os.path.expanduser("~/.openclaw/inbox"),
    os.path.expanduser("~/.openclaw/workspace/al_factory/inbox"),
    os.path.expanduser("~/.openclaw/workspace/inbox")
]
GITHUB_ORG = "johntaylormfc"

def find_spec():
    """Find most recent spec.md from inbox locations"""
    for dir_path in INBOX_DIRS:
        if os.path.isdir(dir_path):
            specs = list(Path(dir_path).glob("**/spec.md"))
            if specs:
                return str(max(specs, key=os.path.getmtime))
    return ""

def parse_intent(text):
    """Parse plain English into structured intent"""
    text = text.lower()
    
    # Default values
    intent = {
        "action": "unknown",
        "app_name": "",
        "repo_name": "",
        "target": "beelink",
        "spec_path": "",
        "deploy": True,
        "push_github": False
    }
    
    # Detect action
    if re.search(r"build.*new|new.*app|create.*app", text):
        intent["action"] = "build_new"
    elif re.search(r"update|modify|change", text):
        intent["action"] = "update_existing"
    elif re.search(r"container only|just.*container|build.*container", text):
        intent["action"] = "container_only"
    elif re.search(r"show.*url|url.*for|what.*url", text):
        intent["action"] = "url_only"
    elif re.search(r"list.*app|show.*app", text):
        intent["action"] = "list_apps"
    
    # Extract app name
    original_text = text
    match = re.search(r"(?:called|named|app\s+|for\s+)\s*([a-zA-Z][-a-zA-Z0-9]*)", original_text)
    if not match:
        match = re.search(r"(?:build|app|project)\s+(?:called\s+)?([a-zA-Z][a-zA-Z0-9]*)", original_text)
    if match:
        intent["app_name"] = match.group(1)
    
    # Detect target
    if "gspro" in text or "gsp" in text:
        intent["target"] = "gspro"
    
    # Check for GitHub push
    if "push" in text and "github" in text:
        intent["push_github"] = True
    
    # Generate repo name
    if intent["app_name"]:
        intent["repo_name"] = intent["app_name"].lower().replace(" ", "-")
    
    # Find spec
    intent["spec_path"] = find_spec()
    
    return intent

def run_cmd(cmd):
    """Run shell command and return output"""
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout + result.stderr

def build_new(intent):
    """Build new AL app"""
    app_name = intent["app_name"]
    repo_name = intent["repo_name"]
    target = intent["target"]
    spec_path = intent["spec_path"]
    push_github = intent["push_github"]
    
    print(f"[bc-workflow] Building new app: {app_name}")
    
    # Create AL skeleton
    app_dir = os.path.join(AL_FACTORY, repo_name)
    os.makedirs(app_dir, exist_ok=True)
    os.makedirs(os.path.join(app_dir, "src"), exist_ok=True)
    os.makedirs(os.path.join(app_dir, "docs"), exist_ok=True)
    
    # Create app.json
    app_json = {
        "id": "00000000-0000-0000-0000-000000000000",
        "name": app_name,
        "publisher": "johntaylormfc",
        "version": "1.0.0.0",
        "platform": "1.0.0.0",
        "application": "22.0.0.0",
        "runtime": "12.0"
    }
    
    import json
    with open(os.path.join(app_dir, "app.json"), "w") as f:
        json.dump(app_json, f, indent=2)
    
    # Copy spec if found
    if spec_path and os.path.exists(spec_path):
        import shutil
        shutil.copy(spec_path, os.path.join(app_dir, "docs", "spec.md"))
    
    # Create README
    with open(os.path.join(app_dir, "README.md"), "w") as f:
        f.write(f"# {app_name}\n\nBusiness Central extension.\n\n## Build\nPress F5 in VS Code\n")
    
    print(f"[bc-workflow] Created AL skeleton at: {app_dir}")
    
    # Push to GitHub
    if push_github:
        print(f"[bc-workflow] Pushing to GitHub...")
        # Check for gh
        if subprocess.run("which gh", shell=True, capture_output=True).returncode == 0:
            # Check gh auth
            if subprocess.run("gh auth status", shell=True, capture_output=True).returncode != 0:
                print("[bc-workflow] WARN: gh not authenticated. Manual push required.")
        else:
            print("[bc-workflow] WARN: gh not installed. Manual push required.")
    
    # Deploy container
    if target == "beelink":
        print("[bc-workflow] Deploying to local container...")
        run_cmd(f"~/.local/bin/bc-new {repo_name} UK latest --dry-run 2>/dev/null")
        run_cmd(f"~/.local/bin/bc-url {repo_name}")
    else:
        print(f"[bc-workflow] WARN: GSPro target not configured, using local")
        run_cmd(f"~/.local/bin/bc-new {repo_name} UK latest --dry-run 2>/dev/null")

def show_url(intent):
    """Show URL for app"""
    app_name = intent.get("app_name", "")
    if not app_name:
        print("[bc-workflow] ERROR: App name required")
        return
    
    repo_name = app_name.lower().replace(" ", "-")
    print(f"[bc-workflow] Showing URL for: {repo_name}")
    run_cmd(f"~/.local/bin/bc-url {repo_name}")

def list_apps():
    """List all apps"""
    print("[bc-workflow] Available containers:")
    run_cmd("~/.local/bin/bc-list")
    print("\n[bc-workflow] AL Factory projects:")
    if os.path.exists(AL_FACTORY):
        for item in os.listdir(AL_FACTORY):
            print(f"  - {item}")
    else:
        print("  (none)")

def main():
    if len(sys.argv) < 2:
        print("Usage: bc-workflow '<plain english command>'")
        print("\nExamples:")
        print("  bc-workflow 'Build a new app called DemoApp and deploy locally'")
        print("  bc-workflow 'Show URL for bcuk-prod'")
        print("  bc-workflow 'List all apps'")
        sys.exit(1)
    
    command = " ".join(sys.argv[1:])
    print(f"[bc-workflow] Processing: {command}")
    
    # Parse intent
    intent = parse_intent(command)
    print(f"[bc-workflow] Parsed intent: {json.dumps(intent)}")
    
    # Execute based on action
    action = intent["action"]
    
    if action == "build_new":
        if not intent["app_name"]:
            print("[bc-workflow] ERROR: App name required")
            sys.exit(1)
        build_new(intent)
    elif action == "update_existing":
        print("[bc-workflow] WARN: Update not fully implemented in Stage 16")
    elif action == "container_only":
        if not intent["app_name"]:
            print("[bc-workflow] ERROR: App name required")
            sys.exit(1)
        repo_name = intent["app_name"].lower().replace(" ", "-")
        run_cmd(f"~/.local/bin/bc-new {repo_name} UK latest --dry-run 2>/dev/null")
        run_cmd(f"~/.local/bin/bc-url {repo_name}")
    elif action == "url_only":
        if not intent["app_name"]:
            print("[bc-workflow] ERROR: App name required")
            sys.exit(1)
        show_url(intent)
    elif action == "list_apps":
        list_apps()
    else:
        print(f"[bc-workflow] ERROR: Could not understand: {command}")
        sys.exit(1)
    
    print("[bc-workflow] Done!")

if __name__ == "__main__":
    main()
